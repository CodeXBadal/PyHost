# ─── Required ────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
FORCE_JOIN_CHANNEL=@YourChannel

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_32byte_fernet_key_here

# MongoDB — use Atlas URI or the local mongo container
MONGO_URI=mongodb://pyhost_mongo:27017
MONGO_DB_NAME=pyhost

# ─── Optional (Premium webhook proxy) ───────────────────────
#PUBLIC_DOMAIN=https://yourdomain.com
#NGINX_SITES_DIR=/etc/nginx/sites-enabled
#BOT_HAS_PREMIUM=false
