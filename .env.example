# ─── REQUIRED ───────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAEXAMPLEEXAMPLEEXAMPLEEXAMPLEEXAMPLE

# Comma-separated Telegram user IDs that get /admin access
ADMIN_IDS=123456789,987654321

# Channel users MUST join (e.g. @MyChannel) — set to empty string to disable
FORCE_JOIN_CHANNEL=@YourChannel

# 32-byte URL-safe base64 key for AES-256 ENV-var encryption
# Generate with:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=PASTE_A_FERNET_KEY_HERE_44_CHARS_LONG=

# ─── INFRA ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017

# ─── OPTIONAL (Premium webhook proxy) ───────────────────────
PUBLIC_DOMAIN=https://pyhost.example.com
NGINX_SITES_DIR=/etc/nginx/sites-enabled
